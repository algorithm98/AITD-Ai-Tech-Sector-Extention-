{
  "manifest_version": 3,
  "name": "AI Tech Detector Pro",
  "version": "2.0",
  "permissions": ["activeTab","scripting","storage","webRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {"default_popup":"popup.html"},
  "background": {"service_worker":"background.js"},
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}
